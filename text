// =======================
// MAIN LOAD FUNCTION
// =======================
function loadPage() {
const reef = reefData[currentReef];

// title + info
document.getElementById("reef-page-title").textContent = reef.title;
document.getElementById("reef-info").textContent = reef.info;

// load all 6 coral images
for (let i = 0; i < reef.corals.length; i++) {
    const coral = reef.corals[i];
    const status = coral[currentYear].status.toLowerCase();
    const imagePath = `Images/${reef.folder}/${coral.file}_${status}.png`;

    const coralBox = document.querySelector(`.coral${i + 1}`);
    coralBox.style.backgroundImage = `url("${imagePath}")`;
    coralBox.style.backgroundSize = "contain";
    coralBox.style.backgroundRepeat = "no-repeat";
    coralBox.style.backgroundPosition = "center";

    // hover = change small label text (changed)
   coralBox.onmouseenter = function () {
const labelCard = document.getElementById("coral-label-card");
const labelText = document.getElementById("coral-label-text");
const displayArea = document.querySelector(".coral-display");

labelText.textContent = coral.name;

const coralRect = coralBox.getBoundingClientRect();
const displayRect = displayArea.getBoundingClientRect();

const leftPosition = coralRect.left - displayRect.left + (coralRect.width / 2) - (labelCard.offsetWidth / 2);
const topPosition = coralRect.top - displayRect.top - 100;

labelCard.style.left = `${leftPosition}px`;
labelCard.style.top = `${topPosition}px`;
labelCard.style.opacity = "1";
};

coralBox.onmouseleave = function () {
const labelCard = document.getElementById("coral-label-card");
labelCard.style.opacity = "0";
};

    // click = show this coral in center text
    coralBox.onclick = function () {
        currentCoral = i;
        showCoralText();
    };
}

// show first selected coral text
showCoralText();

}

// =======================
// SHOW CENTER TEXT
// =======================
function showCoralText() {
const coral = reefData[currentReef].corals[currentCoral];

document.getElementById("coral-name").textContent = coral.name;
document.getElementById("text-blue").textContent = coral.textBlue;
document.getElementById("text-green").textContent = coral.textGreen;
document.getElementById("status-title").innerHTML = `<strong>Status: ${coral[currentYear].status}</strong>`;
document.getElementById("status-text").textContent = coral[currentYear].statusText;
document.getElementById("coral-label-text").textContent = coral.name;

}

// =======================
// YEAR BUTTON CLICK
// =======================
function changeYear(year) {
currentYear = year;
document.querySelectorAll(".year-buttons button").forEach(button => {
    button.classList.remove("active");

    if (button.textContent == year) {
        button.classList.add("active");
    }
});

loadPage();
}


/* ===== RESET DEFAULT BROWSER STYLES ===== */
body {
margin: 0;
padding: 0;
font-family: 'Cascadia Code', monospace;
background-color: #e8e8dc;

/* ✅ NEW: center everything on screen */
height: 100vh;
display: flex;
justify-content: center;
align-items: center;

}

/* ===== MAIN CONTAINER ===== */
.container {
text-align: center;

/* ✅ UPDATED: better responsive spacing */
width: 90%;
max-width: 1200px;

}

/* ===== TITLE ===== */
h1 {
font-size: 72px;
margin-bottom: 10px;
}

/* ===== SUBTITLE ===== */
.subtitle {
font-size: 20px;

/* ✅ REDUCED: was too large and broke centering */
margin-bottom: 150px;

}

/* ===== CORAL ROW (IMPORTANT PART) ===== */
.coral-row {
display: flex;
justify-content: center;
/* ✅ NEW: makes layout responsive */
flex-wrap: wrap;

gap: 40px;

/* ✅ NEW: bottom line */
border-bottom: 2px solid black;
padding-bottom: 20px;

}

/* ===== EACH CORAL BLOCK ===== */
.coral {
position: relative;
cursor: pointer;
transition: transform 0.3s ease;
}

/* ===== CORAL IMAGE ===== */
.coral img {
/* ✅ UPDATED: responsive sizing */
width: 10vw;
min-width: 100px;
max-width: 160px;
}

/* ===== HOVER EFFECT (MOVE UP) ===== */
.coral:hover {
transform: translateY(-10px);
}

/* ===== LABEL (HIDDEN BY DEFAULT) ===== */
.label {
position: absolute;
top: -100px;
left: 50%;
transform: translateX(-50%);

background-color: #e8e8dc;
border: 2px solid black;
border-radius: 15px;
padding: 5px 10px;
font-size: 16px;

opacity: 0;
transition: opacity 0.3s ease;

}

/* ===== SHOW LABEL ON HOVER ===== */
.coral:hover .label {
opacity: 1;
}

/* ===== NEW: LINE FROM CORAL TO LABEL ===== */
.coral::before {
content: "";
position: absolute;
/* starts from top of coral */
top: -60px;
left: 50%;
transform: translateX(-50%);

width: 2px;
height: 60px;

background-color: black;

opacity: 0;
transition: opacity 0.3s ease;

}

/* show line on hover */
.coral:hover::before {
opacity: 1;
}

/* =========================================
REEF PAGE
========================================= */

/* full screen background */
.reef-container {
width: 100%;
height: 100vh;
background-image: url("Images/Background.png");
background-size: cover;
background-position: center;
background-repeat: no-repeat;

display: flex;
justify-content: center;
align-items: center;
padding: 100px;
box-sizing: border-box;
}

/* main inner panel */
.reef-panel {
width: 92%;
height: 72vh;
background-color: #e8e8dc;
border-radius: 26px;
position: relative;
padding: 50px 60px 50px 60px;
box-sizing: border-box;
overflow: hidden;
}

/* =========================================
TOP BAR
========================================= */
.top-bar {
display: grid;
grid-template-columns: auto 1fr auto;
align-items: center;
column-gap: 20px;
}

/* back button */
.back-btn {
width: 42px;
height: 42px;
border: 2px solid black;
border-radius: 50%;
background-color: #e8e8dc;
font-family: 'Cascadia Code', monospace;
font-size: 22px;
cursor: pointer;
display: flex;
justify-content: center;
align-items: center;
padding: 0;
}

/* reef title capsule */
.reef-title-box {
width: 500px;
max-width: 100%;
height: 40px;
border: 2px solid black;
border-radius: 24px;
background-color: #e8e8dc;
display: flex;
align-items: center;
justify-content: center;
}

#reef-page-title {
margin: 0;
font-size: 18px;
line-height: 1;
}

/* year area */
.year-section {
width: 360px;
position: relative;
display: flex;
justify-content: center;
align-items: center;
}

.year-line {
position: absolute;
width: 100%;
height: 2px;
background-color: black;
top: 50%;
left: 0;
transform: translateY(-50%);
}

.year-buttons {
position: relative;
z-index: 2;
display: flex;
gap: 20px;
}

.year-buttons button {
width: 66px;
height: 38px;
border: 2px solid black;
border-radius: 20px;
background-color: #e8e8dc;
font-family: 'Cascadia Code', monospace;
font-size: 16px;
cursor: pointer;
transition: height 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
}

.year-buttons button:hover {
height: -10px;
transform: translateX(2px);
box-shadow: 2px 0 0 black;
}

.year-buttons button.active {
height: 44px;
transform: translateX(2px);
box-shadow: 2px 0 0 black;
}

